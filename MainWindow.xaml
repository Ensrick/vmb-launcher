<Window x:Class="VmbLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VMB Launcher" Height="640" Width="1024"
        Background="#1E1E1E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#3E3E42"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Background" Value="#1F1F22"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#2A2A2D"/></Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#094771"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#3E3E42">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnRefresh" Content="↻ Refresh" Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnNewMod" Content="+ New Mod" Click="BtnNewMod_Click"/>
                    <Button x:Name="BtnSettings" Content="⚙ Settings" Click="BtnSettings_Click"/>
                </StackPanel>
                <TextBlock x:Name="TbStatus" DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#9CDCFE" Text=""/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="LbMods" Grid.Column="0" SelectionChanged="LbMods_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Foreground="#9CDCFE" FontSize="11"/>
                                <TextBlock Text="  ·  " Foreground="#6B6B6B" FontSize="11"/>
                                <TextBlock Text="{Binding Visibility}" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#9CDCFE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Visibility}" Value="public">
                                                    <Setter Property="Foreground" Value="#F48771"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="  ·  " Foreground="#6B6B6B" FontSize="11"/>
                                <TextBlock Text="{Binding BuiltStatus}" FontSize="11" Foreground="#6B6B6B"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Column="1" Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TbModTitle" Grid.Row="0" FontSize="22" FontWeight="SemiBold" Text="Select a mod"/>
                <TextBlock x:Name="TbModSub" Grid.Row="1" Foreground="#9CDCFE" FontSize="12" Margin="0,2,0,12" Text=""/>

                <StackPanel x:Name="SpActions" Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12" IsEnabled="False">
                    <Button x:Name="BtnBuild" Content="Build" Click="BtnBuild_Click" Padding="18,8"/>
                    <Button x:Name="BtnDeploy" Content="Deploy" Click="BtnDeploy_Click" Padding="18,8"/>
                    <Button x:Name="BtnUpload" Content="Upload" Click="BtnUpload_Click" Padding="18,8"/>
                    <Button x:Name="BtnAll" Content="Build + Deploy + Upload" Click="BtnAll_Click" Padding="18,8" Background="#0E639C" BorderBrush="#1177BB"/>
                    <Separator Width="14" Background="Transparent"/>
                    <Button x:Name="BtnSubscribe" Content="Subscribe in Steam" Click="BtnSubscribe_Click"/>
                    <Button x:Name="BtnOpenFolder" Content="Open Mod Folder" Click="BtnOpenFolder_Click"/>
                </StackPanel>

                <Border Grid.Row="3" Background="#0C0C0C" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Background="#1F1F1F" LastChildFill="False">
                            <TextBlock Text="Output" Margin="10,6" FontWeight="SemiBold"/>
                            <Button x:Name="BtnClearLog" DockPanel.Dock="Right" Content="Clear" Click="BtnClearLog_Click" Margin="0,3,6,3" Padding="10,2"/>
                        </DockPanel>
                        <TextBox x:Name="TbLog" Grid.Row="1"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 TextWrapping="NoWrap"
                                 FontSize="12"
                                 Foreground="#CCCCCC"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#007ACC" Padding="10,4">
            <DockPanel>
                <TextBlock x:Name="TbStatusBar" Text="Ready" Foreground="White" FontSize="12"/>
                <TextBlock x:Name="TbVmbInfo" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="White" FontSize="12" Text=""/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
